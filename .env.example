# ============================================
# Ghost Host — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Local PostgreSQL container (optional for local-only development)
POSTGRES_USER=343
POSTGRES_PASSWORD=
POSTGRES_DB=yyyy

# Spring datasource (use Supabase Postgres for free public hosting)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-supabase-pooler-host:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.your_project_ref
SPRING_DATASOURCE_PASSWORD=your_supabase_database_password

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# Supabase Storage
SUPABASE_URL=url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=55

# Domain (used for subdomain routing)
BASE_DOMAIN=127.0.0.1.nip.io

# GitHub Actions Integration
GITHUB_PAT=your_github_personal_access_token_here
GITHUB_REPO=your_github_username/ghost

# Internal API Secret for GHA Callback (generate with: openssl rand -base64 32)
INTERNAL_API_KEY=your_internal_api_key_here
API_URL=http://localhost:8081
