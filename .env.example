# ============================================
# Ghost Host — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# PostgreSQL
POSTGRES_USER=ghosthost
POSTGRES_PASSWORD=changeme_pg_password
POSTGRES_DB=ghosthost

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Cloudflare R2
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=ghosthost-deployments
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Domain (used for subdomain routing)
BASE_DOMAIN=mydomain.com

# Docker build limits
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_LIMIT=1
BUILD_TIMEOUT_SECONDS=300
