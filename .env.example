# ============================================
# Ghost Host — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# PostgreSQL
POSTGRES_USER=ghosthost
POSTGRES_PASSWORD=changeme_pg_password
POSTGRES_DB=ghosthost

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# Supabase Storage
SUPABASE_URL=https://xqqdvcgghvjsjhbewzjr.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=ghosthost-deployments

# Domain (used for subdomain routing)
BASE_DOMAIN=127.0.0.1.nip.io

# Docker build limits
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_LIMIT=1
BUILD_TIMEOUT_SECONDS=300
